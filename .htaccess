# .htaccess — Time2Crack v2 Cache Configuration
# Cache-Control headers for optimal performance
# Reference: https://developer.mozilla.org/en-US/docs/Web/HTTP/Headers/Cache-Control

# Enable mod_headers if not already enabled
<IfModule mod_headers.c>

  # ─────────────────────────────────────────────────────────────────────────────
  # Static Data Files (7 days) — JSON, TXT wordlists
  # These are updated rarely and can be cached aggressively
  # ─────────────────────────────────────────────────────────────────────────────
  <FilesMatch "\.(json|txt)$">
    Header set Cache-Control "public, max-age=604800, immutable"
    # 604800 seconds = 7 days
    # immutable: Don't revalidate unless user explicitly refreshes
  </FilesMatch>

  # ─────────────────────────────────────────────────────────────────────────────
  # Application Files (1 year) — JS, CSS
  # Only requested if URL changes (e.g., app-v2.1.js)
  # Safe to cache indefinitely since filename includes version
  # ─────────────────────────────────────────────────────────────────────────────
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
    # 31536000 seconds = 1 year
    # immutable: Never revalidate
  </FilesMatch>

  # ─────────────────────────────────────────────────────────────────────────────
  # HTML Pages (No cache) — Always revalidate
  # Users should always get latest version of the app
  # ─────────────────────────────────────────────────────────────────────────────
  <FilesMatch "\.html?$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
    # max-age=0: Don't use cached version
    # must-revalidate: Check with server even if stale
  </FilesMatch>

  # ─────────────────────────────────────────────────────────────────────────────
  # Media/Fonts (30 days) — SVG, WOFF2, etc.
  # ─────────────────────────────────────────────────────────────────────────────
  <FilesMatch "\.(svg|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=2592000"
    # 2592000 seconds = 30 days
  </FilesMatch>

</IfModule>

# ───────────────────────────────────────────────────────────────────────────────
# Fallback: If mod_headers not available, use mod_expires
# ───────────────────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # Data files (7 days)
  ExpiresByType application/json                "access plus 7 days"
  ExpiresByType text/plain                      "access plus 7 days"

  # App files (1 year)
  ExpiresByType application/javascript          "access plus 1 year"
  ExpiresByType text/css                        "access plus 1 year"

  # HTML (no cache)
  ExpiresByType text/html                       "access"

  # Media/Fonts (30 days)
  ExpiresByType image/svg+xml                   "access plus 30 days"
  ExpiresByType font/woff                       "access plus 30 days"
  ExpiresByType font/woff2                      "access plus 30 days"
</IfModule>
