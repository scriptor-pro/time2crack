<meta name="description" content="{{ pageDescription }}">
<meta name="robots" content="{{ robots | default('index,follow') }}">
<meta name="theme-color" content="#2563EB">

<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDescription }}">
<meta property="og:image" content="{{ site.baseUrl }}/logo.png">
<meta property="og:type" content="{{ ogType | default('article') }}">
<meta property="og:url" content="{{ site.baseUrl }}/{{ lang }}/{{ pageSlug }}">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:locale" content="{{ site.langLocales[lang] }}">
{% for otherLang in site.langs %}{% if otherLang != lang %}
<meta property="og:locale:alternate" content="{{ site.langLocales[otherLang] }}">
{% endif %}{% endfor %}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ pageTitle }}">
<meta name="twitter:description" content="{{ pageDescription }}">
<meta name="twitter:image" content="{{ site.baseUrl }}/logo.png">

<link rel="canonical" href="{{ site.baseUrl }}/{{ lang }}/{{ pageSlug }}">
{% for hLang in site.langs %}
<link rel="alternate" hreflang="{{ hLang }}" href="{{ site.baseUrl }}/{{ hLang }}/{{ pageSlug }}">
{% endfor %}
<link rel="alternate" hreflang="x-default" href="{{ site.baseUrl }}/en/{{ pageSlug }}">
