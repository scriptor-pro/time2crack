{% set t = i18n[lang] %}
<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ t.dir | default('ltr') }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle }}</title>
  {% if criticalCss %}{{ "" | getCriticalCss | safe }}{% endif %}
  <link rel="preload" href="/style.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="/style.min.css"></noscript>
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin>
  <link rel="preload" href="https://fonts.bunny.net/css?family=oxanium:600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.bunny.net/css?family=oxanium:600&display=swap"></noscript>
  <link rel="preload" href="https://fonts.bunny.net/css?family=ibm-plex-sans:300,400,500,600|ibm-plex-mono:400,500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.bunny.net/css?family=ibm-plex-sans:300,400,500,600|ibm-plex-mono:400,500&display=swap"></noscript>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="57x57" href="/apple-touch-icon-57x57.png">
  <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png">
  {% include "head-meta.njk" %}
  <script src="{{ site.umamiSrc }}" data-website-id="{{ site.umamiId }}" defer></script>
</head>
<body>
{% include "nav.njk" %}
<main class="{{ mainClass | default('') }}">
  {{ content | safe }}
</main>
{% include "footer.njk" %}
{% block scripts %}
<script src="/includes.js" defer></script>
{% endblock %}
</body>
</html>
