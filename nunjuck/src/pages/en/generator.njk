<span class="charset-range">(A-Z)</span>
</label>
<label class="charset-option">
<input aria-label="Minuscules" checked="" id="include-lowercase" type="checkbox">
<span class="charset-label">Minuscules</span>
<span class="charset-range">(a-z)</span>
</label>
<label class="charset-option">
<input aria-label="Figures" checked="" id="include-numbers" type="checkbox">
<span class="charset-label">Figures</span>
<span class="charset-range">(0-9)</span>
</label>
<label class="charset-option">
<input aria-label="Symbols" checked="" id="include-symbols" type="checkbox">
<span class="charset-label">Symbols</span>
<span class="charset-range">(!</span>
</label>
</div>
</fieldset>
<fieldset class="control-group">
<legend>Advanced Options:</legend>
<label>
<input aria-label="Avoid ambiguous" checked="" id="exclude-ambiguous" type="checkbox">
