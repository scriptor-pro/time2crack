<p>const res = aspetta fetch(<code>data/wordlists/${lang}.txt</code>);
const text = attendere res.text();</p>
<p>// Convertire in Impostare l'abbronzatura &gt; per la ricerca O(1)
DICT<em>WORDS = nuovo set(
text.split("\n")
.map(w =&gt; w.normalize("NFC").trim().toLowerCase()
